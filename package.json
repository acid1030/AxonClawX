{
  "name": "axonclaw",
  "version": "1.0.0",
  "description": "AxonClaw - OpenClaw Desktop Client with Electron + React 19",
  "main": "./out/main/index.js",
  "author": "OpenClaw Team",
  "license": "MIT",
  "bin": {
    "axon": "./out/cli/index.js"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "npm run build:main && npm run build:preload && concurrently \"vite\" \"wait-on http://localhost:5173 && NODE_ENV=development VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "electron:build": "npm run build:main && npm run build:preload && vite build && electron-builder",
    "electron:build:dir": "npm run electron:build -- --dir",
    "electron:build:mac": "npm run electron:build -- --mac",
    "electron:build:win": "npm run electron:build -- --win",
    "electron:build:linux": "npm run electron:build -- --linux",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "cli:dev": "tsx cli/index.ts",
    "cli:build": "tsc -p tsconfig.cli.json",
    "cli:test": "tsx cli/index.ts status",
    "package": "npm run electron:build",
    "release": "npm run electron:build -- --publish always",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.0.4",
    "better-sqlite3": "^12.8.0",
    "check-disk-space": "^3.4.0",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.0",
    "commander": "^11.1.0",
    "framer-motion": "^12.36.0",
    "i18next": "^25.8.18",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.8",
    "react-markdown": "^9.0.1",
    "react-syntax-highlighter": "^15.6.1",
    "remark-gfm": "^4.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.2.0",
    "uuid": "^9.0.0",
    "ws": "^8.19.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.11.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^9.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.0",
    "electron": "^33.0.0",
    "electron-builder": "^24.13.0",
    "electron-rebuild": "^3.2.9",
    "playwright": "^1.58.2",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.3.0",
    "vite": "^5.1.0",
    "wait-on": "^7.2.0"
  }
}
