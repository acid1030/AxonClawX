# 监听（上游 nginx 反代时保持 127.0.0.1）
HOST=127.0.0.1
PORT=3450

# JWT 对称密钥，生产请用 openssl rand -base64 48
JWT_SECRET=change-me-to-long-random-string-min-32-chars

# 正文目录（与 taiyi-novel-site 相同：卷二正文）
TAIYI_CONTENT_DIR=/path/to/卷二正文

# 首次启动若库中无用户，用以下账号创建管理员（仅一次）
BOOTSTRAP_ADMIN_USER=admin
BOOTSTRAP_ADMIN_PASS=change-bootstrap-password

# 设为 1 时开放自助注册（仅建议内网/测试）；生产请关并用 INVITE_CODE 或仅管理员建号
ALLOW_REGISTER=0

# 开放注册邀请码；与 ALLOW_REGISTER=1 二选一或同开
INVITE_CODE=

# 访问令牌分钟数（默认 30，与此前「30 分钟免验证」一致）
ACCESS_TOKEN_MINUTES=30

# 刷新令牌天数
REFRESH_TOKEN_DAYS=30
